---
import { getCollection } from 'astro:content';
import { formatDate, readingTime } from '../../lib/blog';
import '../../styles/global.css';

const allDocs = (await getCollection('docs', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

// Collect all unique tags, sorted — year tags sorted descending, rest alphabetically
const tagSet = new Set<string>();
allDocs.forEach((p) => p.data.tags.forEach((t) => tagSet.add(t)));
const yearTags = [...tagSet].filter((t) => /^\d{4}$/.test(t)).sort((a, b) => Number(b) - Number(a));
const otherTags = [...tagSet].filter((t) => !/^\d{4}$/.test(t)).sort();
const ALL_TAGS = [...otherTags, ...yearTags];

const DOCS_JSON = JSON.stringify(
  allDocs.map((p) => ({
    title: p.data.title,
    desc: p.data.description,
    tags: p.data.tags,
    date: formatDate(p.data.date),
    ts: p.data.date.valueOf(),
    read: readingTime(p.body ?? ''),
    href: `/docs/${p.id.replace(/\.mdx?$/, '')}`,
  }))
);

const TAGS_JSON = JSON.stringify(ALL_TAGS);

const year = new Date().getFullYear();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Docs — Preah</title>
    <meta name="description" content="Labs, runbooks, and reference material." />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Crimson+Pro:ital,wght@0,300..700;1,300..600&family=Source+Serif+4:opsz,wght@8..60,300..600&family=Spline+Sans+Mono:wght@400;500&family=Newsreader:opsz,wght@6..72,400..600&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <div class="wrap">

      <!-- ---------- site header ---------- -->
      <header class="site-head">
        <div class="brand-row">
          <span class="brand-icon" aria-hidden="true">
            <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.0" stroke-linecap="round" stroke-linejoin="round"><path d="M10 2v2"/><path d="M14 2v2"/><path d="M16 8a1 1 0 0 1 1 1v8a4 4 0 0 1-4 4H7a4 4 0 0 1-4-4V9a1 1 0 0 1 1-1h14a4 4 1 1 1 0 8h-1"/><path d="M6 2v2"/></svg>
          </span>
          <a class="brand" href="/">Preah</a>
        </div>
        <nav class="nav">
          <a href="/">home</a>
          <a href="/blog">blog</a>
          <a href="/docs" class="active">docs</a>
          <a href="/homelab">homelab</a>
          <a href="/portfolio">portfolio</a>
          <a href="/about">about</a>
        </nav>
      </header>

      <!-- ---------- two-column landing ---------- -->
      <div class="landing">

        <!-- LEFT RAIL: tag filter -->
        <aside>
          <div class="tag-box">
            <div class="tag-box-label">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 2H2v10l9.29 9.29a1 1 0 0 0 1.41 0l7.3-7.3a1 1 0 0 0 0-1.41L12 2Z"/><circle cx="7" cy="7" r="1" fill="currentColor"/></svg>
              Filter by tag
            </div>
            <ul class="tag-list" id="tag-list"></ul>
          </div>
        </aside>

        <!-- RIGHT COLUMN: previews -->
        <main>
          <div class="feed-intro">
            <p>Labs, runbooks, and reference material. Things I write down so I can find them again, and what makes up the bulk of my time writing.</p>
          </div>
          <div class="feed-here" id="here">Showing <b>most recent</b> docs</div>
          <div id="previews"></div>
        </main>
      </div>

      <!-- ---------- footer ---------- -->
      <footer class="site-foot">
        <span class="foot-brand">Preah</span>
        <span class="foot-dot">&middot;</span>
        <span>{year}</span>
        <span class="foot-spacer"></span>
        <a href="https://git.preahs.com/preah">Forgejo</a>
        <a href="mailto:contact@preahs.com">Email</a>
        <a href="/rss.xml">RSS</a>
        <a href="https://signal.me/#eu/7FQaEphPdhSrlUCPuqr8awsHVYUSiJ9CGua_YktOEMge3oIT-itMcKuS2r3k6x8Q">Signal</a>
        <a href="https://matrix.to/#/@preshavocado:snowberry.social">Matrix</a>
      </footer>
    </div>

    <script define:vars={{ DOCS_JSON, TAGS_JSON }}>
      var DOCS = JSON.parse(DOCS_JSON);
      var TAGS  = JSON.parse(TAGS_JSON);

      var calIcon   = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"><rect x="3" y="4" width="18" height="17" rx="2"/><path d="M3 9h18M8 2v4M16 2v4"/></svg>';
      var clockIcon = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2"/></svg>';
      var tagIcon   = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2H2v10l9.29 9.29a1 1 0 0 0 1.41 0l7.3-7.3a1 1 0 0 0 0-1.41L12 2Z"/><circle cx="7" cy="7" r="1" fill="currentColor"/></svg>';

      var selected = null; // null = all docs

      function buildTagList() {
        var ul = document.getElementById('tag-list');
        ul.innerHTML = '';

        // "All" entry
        var allLi = document.createElement('li');
        var allBtn = document.createElement('button');
        allBtn.className = 'tag-item' + (selected === null ? ' selected' : '');
        allBtn.textContent = 'All docs';
        allBtn.addEventListener('click', function() { selected = null; refresh(); });
        allLi.appendChild(allBtn);
        ul.appendChild(allLi);

        TAGS.forEach(function(tag) {
          var count = DOCS.filter(function(p) { return p.tags.indexOf(tag) > -1; }).length;
          var li = document.createElement('li');
          var btn = document.createElement('button');
          btn.className = 'tag-item' + (selected === tag ? ' selected' : '');
          btn.innerHTML = escHtml(tag) + '<span class="tag-count">' + count + '</span>';
          btn.addEventListener('click', function() {
            selected = (selected === tag) ? null : tag;
            refresh();
          });
          li.appendChild(btn);
          ul.appendChild(li);
        });
      }

      function renderPreviews() {
        var list = selected === null
          ? DOCS
          : DOCS.filter(function(p) { return p.tags.indexOf(selected) > -1; });

        var here = document.getElementById('here');
        if (selected === null) {
          here.innerHTML = 'Showing <b>most recent</b> docs';
        } else {
          here.innerHTML = 'Tagged <b>' + escHtml(selected) + '</b> &middot; ' +
            list.length + ' doc' + (list.length === 1 ? '' : 's');
        }

        var box = document.getElementById('previews');
        if (list.length === 0) {
          box.innerHTML = '<p class="empty">No docs with this tag yet.</p>';
          return;
        }

        box.innerHTML = list.map(function(p) {
          var tagPills = p.tags.map(function(t) {
            return '<button class="preview-tag" data-tag="' + escAttr(t) + '">' + escHtml(t) + '</button>';
          }).join('');

          return '<article class="preview">' +
            '<a class="title" href="' + p.href + '">' + escHtml(p.title) + '</a>' +
            '<p class="desc">' + escHtml(p.desc) + '</p>' +
            '<div class="meta">' +
              '<span class="mi" aria-hidden="true">' + calIcon + '</span>' +
              '<span>' + escHtml(p.date) + '</span>' +
              '<span class="gap"></span>' +
              '<span class="mi" aria-hidden="true">' + clockIcon + '</span>' +
              '<span>' + escHtml(p.read) + '</span>' +
            '</div>' +
            '<div class="preview-tags">' + tagPills + '</div>' +
          '</article>';
        }).join('');

        // Wire up tag click on preview cards
        box.querySelectorAll('.preview-tag').forEach(function(btn) {
          btn.addEventListener('click', function() {
            var tag = btn.getAttribute('data-tag');
            selected = (selected === tag) ? null : tag;
            refresh();
          });
        });
      }

      function refresh() {
        buildTagList();
        renderPreviews();
        // Update URL without reload
        var url = new URL(window.location.href);
        if (selected) {
          url.searchParams.set('tag', selected);
        } else {
          url.searchParams.delete('tag');
        }
        history.replaceState(null, '', url.toString());
      }

      function escHtml(str) {
        return String(str)
          .replace(/&/g, '&amp;')
          .replace(/</g, '&lt;')
          .replace(/>/g, '&gt;')
          .replace(/"/g, '&quot;');
      }

      function escAttr(str) {
        return String(str).replace(/"/g, '&quot;').replace(/'/g, '&#39;');
      }

      // Read ?tag= param on load
      var params = new URLSearchParams(window.location.search);
      var tagParam = params.get('tag');
      if (tagParam && TAGS.indexOf(tagParam) > -1) {
        selected = tagParam;
      }

      buildTagList();
      renderPreviews();
    </script>
  </body>
</html>

<style is:global>
  .landing {
    display: grid;
    grid-template-columns: 240px 1fr;
    gap: 2.5rem;
    align-items: start;
    padding-bottom: 3rem;
  }
  @media (max-width: 760px) {
    .landing { grid-template-columns: 1fr; gap: 1.75rem; }
  }

  /* ---- feed intro ---- */
  .feed-intro p { color: var(--ink); font-size: 1.1rem; margin-bottom: 0.6rem; }
  .feed-here {
    font-family: var(--font-mono); font-size: 0.78rem;
    color: var(--ink-faint); margin-bottom: 1.4rem;
  }
  .feed-here b { color: var(--accent); font-weight: 500; }
  .empty { color: var(--ink-faint); font-style: italic; padding: 1rem 0; }

  /* ---- tag filter box ---- */
  .tag-box {
    border: 1.5px dashed var(--rule);
    border-radius: var(--radius);
    padding: 1.1rem 1.2rem;
    background: var(--paper-card);
  }

  .tag-box-label {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--ink-faint);
    margin-bottom: 0.85rem;
  }
  .tag-box-label svg { width: 1rem; height: 1rem; flex: none; }

  .tag-list { list-style: none; display: flex; flex-direction: column; gap: 0.2rem; }

  .tag-item {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    padding: 0.3rem 0.5rem;
    border-radius: 5px;
    border: none;
    background: none;
    cursor: pointer;
    font-family: var(--font-body, inherit);
    font-size: 0.97rem;
    color: var(--accent);
    text-align: left;
    transition: background 0.13s;
    user-select: none;
  }
  .tag-item:hover { background: var(--accent-soft); }
  .tag-item.selected { background: var(--accent-soft); font-weight: 500; text-decoration: underline; text-underline-offset: 3px; }

  .tag-count {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--ink-faint);
    margin-left: 0.35rem;
    flex: none;
  }

  /* ---- doc preview cards ---- */
  .preview {
    border-bottom: 1.5px dashed var(--rule);
    padding-bottom: 1.4rem;
    margin-bottom: 1.4rem;
  }
  .preview:last-child { border-bottom: none; }

  .preview .title {
    display: block;
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 1.25rem;
    color: var(--ink);
    text-decoration: none;
    margin-bottom: 0.3rem;
    line-height: 1.25;
  }
  .preview .title:hover { color: var(--accent); }

  .preview .desc {
    font-size: 0.97rem;
    color: var(--ink-soft);
    margin-bottom: 0.55rem;
    line-height: 1.5;
  }

  .preview .meta {
    display: flex;
    align-items: center;
    gap: 0.45rem;
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--ink-faint);
    margin-bottom: 0.55rem;
  }
  .preview .meta .mi { display: flex; width: 1rem; flex: none; }
  .preview .meta .mi svg { width: 1rem; height: 1rem; }
  .preview .meta .gap { flex: none; width: 0.6rem; }

  .preview-tags { display: flex; flex-wrap: wrap; gap: 0.3rem; }
  .preview-tag {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--accent);
    padding: 0.1em 0.55em;
    border: 1px dashed var(--rule-strong);
    border-radius: 999px;
    background: #FEFCF6;
    cursor: pointer;
    transition: border-color 0.13s, background 0.13s;
  }
  .preview-tag:hover { border-color: var(--accent); background: var(--accent-soft); }
</style>
