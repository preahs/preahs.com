---
import { getCollection, render } from 'astro:content';
import BlogPostLayout from '../../layouts/BlogPostLayout.astro';
import { formatDateTime, readingTime } from '../../lib/blog';


export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  const sorted = posts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

  return sorted.map((post, i) => {
    const slug = post.id.replace(/\.mdx?$/, '');
    const prev = sorted[i + 1]; // older
    const next = sorted[i - 1]; // newer

    return {
      params: { slug },
      props: {
        post,
        prev: prev
          ? { title: prev.data.title, href: `/blog/${prev.id.replace(/\.mdx?$/, '')}` }
          : undefined,
        next: next
          ? { title: next.data.title, href: `/blog/${next.id.replace(/\.mdx?$/, '')}` }
          : undefined,
      },
    };
  });
}

const { post, prev, next } = Astro.props;
const { Content, headings } = await render(post);
const slug = post.id.replace(/\.mdx?$/, '');
const rawHref = post.data.rawSource ? `/blog/${slug}.md` : undefined;
const tocHeadings = post.data.toc ? headings.filter(h => h.depth <= 3) : [];
---

<BlogPostLayout
  title={post.data.title}
  description={post.data.description}
  date={formatDateTime(post.data.date)}
  tags={post.data.tags}
  readingTime={readingTime(post.body ?? '')}
  slug={slug}
  prev={prev}
  next={next}
  rawHref={rawHref}
  toc={tocHeadings}
>
  <Content />
</BlogPostLayout>
