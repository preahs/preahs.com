---
import "../styles/global.css";
import { getCollection } from "astro:content";
import { formatDate, readingTime } from "../lib/blog";

const recentPosts = (await getCollection("blog", ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3)
  .map((p) => ({
    title: p.data.title,
    desc: p.data.description,
    folder: p.data.tags[0] ?? '',
    href: `/blog/${p.id.replace(/\.mdx?$/, "")}`,
    date: formatDate(p.data.date),
    read: readingTime(p.body ?? ""),
  }));

// Current rotation. `note` is optional.
const games = [
  { name: "Skyrim", note: "Since forever! And I mod it too" },
  { name: "Kingdom: Two Crowns", note: "New!" },
  { name: "Oblivion Remastered", note: null },
  { name: "Spelunky 2", note: null },
  { name: "Minecraft", note: "Custom fantasy-focused modpack" },
];

const year = new Date().getFullYear();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Hi, I'm Preah</title>
    <meta
      name="description"
      content="Personal updates, rants, and thoughts. An amateur web developer, infosec tinkerer, tea enthusiast, and homelab enjoyer in Central Texas."
    />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Crimson+Pro:ital,wght@0,300..700;1,300..600&family=Source+Serif+4:opsz,wght@8..60,300..600&family=Spline+Sans+Mono:wght@400;500&family=Newsreader:opsz,wght@6..72,400..600&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <div class="wrap">
      <!-- ---------- site header (shared with blog) ---------- -->
      <header class="site-head">
        <div class="brand-row">
          <span class="brand-icon" aria-hidden="true">
            <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.0" stroke-linecap="round" stroke-linejoin="round"><path d="M10 2v2"/><path d="M14 2v2"/><path d="M16 8a1 1 0 0 1 1 1v8a4 4 0 0 1-4 4H7a4 4 0 0 1-4-4V9a1 1 0 0 1 1-1h14a4 4 1 1 1 0 8h-1"/><path d="M6 2v2"/></svg>
          </span>
          <a class="brand" href="/">Preah</a>
        </div>
        <nav class="nav">
          <a href="/" class="active">home</a>
          <a href="/blog">blog</a>
          <a href="/docs">docs</a>
          <a href="/homelab">homelab</a>
          <a href="/portfolio">portfolio</a>
          <a href="/about">about</a>
        </nav>
      </header>

      <!-- ---------- hero ---------- -->
      <section class="hero">
        <h1>Hi, I'm Preah.</h1>
        <p class="hero-sub">
          I'm a university student living in <a href="https://en.wikipedia.org/wiki/Texas_Hill_Country" target="_blank" rel="noopener noreferrer">the Texas Hill Country</a>. I'm an information-security-obsessed tinkerer and amateur web developer who loves making little projects, an
          occasional gamer (when I'm not doing school or reading), a gong fu tea enthusiast, and a
          homelab / self-host enjoyer.
        </p>
        <p class="hero-sub">
          Expect short personal updates, rants, and other thoughts, possibly
          the odd game review, although I don't try new games often&nbsp;:)
        </p>
        <p class="hero-sub hero-callout">If you're intrigued by my professional work, write-ups, resume, or career goals, visit my <a href="/portfolio">portfolio</a> and definitely read my <a href="/blog">blog</a>!</p>
        <div class="hero-cta">
          <a class="btn" href="/blog">Read the blog</a>
          <a class="btn" href="/about">More about me</a>
        </div>
      </section>

      <!-- ---------- recent writing ---------- -->
      <section class="block">
        <div class="block-head">
          <h2>Recent writing</h2>
          <a class="more" href="/blog">all posts &#8594;</a>
        </div>

        <div class="posts">
          {recentPosts.map((p) => (
            <article class="preview">
              <a class="title" href={p.href}>{p.title}</a>
              <p class="desc">{p.desc}</p>
              <div class="meta">
                <span class="mi" aria-hidden="true">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"><rect x="3" y="4" width="18" height="17" rx="2"/><path d="M3 9h18M8 2v4M16 2v4"/></svg>
                </span>
                <span>{p.date}</span>
                <span class="gap"></span>
                <span class="mi" aria-hidden="true">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2"/></svg>
                </span>
                <span>{p.read}</span>
                <span class="gap"></span>
                <span class="folder-pill">{p.folder}</span>
              </div>
            </article>
          ))}
        </div>
      </section>

      <!-- ---------- currently playing ---------- -->
      <section class="block">
        <div class="block-head">
          <h2>What I'm playing</h2>
          <span class="more-static">current rotation</span>
        </div>

        <ul class="games">
          {games.map((g) => (
            <li class="game">
              <span class="game-ficon" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M6 11h4M8 9v4"/><circle cx="15.5" cy="10.5" r="0.6" fill="currentColor"/><circle cx="17.5" cy="12.5" r="0.6" fill="currentColor"/><path d="M17.5 5.5H6.5A4.5 4.5 0 0 0 2 10v4a3 3 0 0 0 5.4 1.8l.5-.7a2 2 0 0 1 1.6-.8h5a2 2 0 0 1 1.6.8l.5.7A3 3 0 0 0 22 14v-4a4.5 4.5 0 0 0-4.5-4.5Z"/></svg>
              </span>
              <span class="game-name">{g.name}</span>
              {g.note && <span class="game-note">{g.note}</span>}
            </li>
          ))}
        </ul>
      </section>

      <!-- ---------- footer ---------- -->
      <footer class="site-foot">
        <span class="foot-brand">Preah</span>
        <span class="foot-dot">&middot;</span>
        <span>{year}</span>
        <span class="foot-spacer"></span>
        <a href="https://git.preahs.com/preah">Forgejo</a>
        <a href="mailto:contact@preahs.com">Email</a>
        <a href="/rss.xml">RSS</a>
        <a href="https://signal.me/#eu/7FQaEphPdhSrlUCPuqr8awsHVYUSiJ9CGua_YktOEMge3oIT-itMcKuS2r3k6x8Q">Signal</a>
        <a href="https://matrix.to/#/@preshavocado:snowberry.social">Matrix</a>
      </footer>
    </div>
  </body>
</html>
