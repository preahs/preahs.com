---
import '../styles/global.css';
import { categoryLabel } from '../lib/blog';

interface Props {
  title: string;
  description: string;
  date: string;         // pre-formatted string, e.g. "Sun May. 17, 2026"
  category: string;     // category id, e.g. "codex"
  readingTime: string;  // e.g. "5 min read"
  prev?: { title: string; href: string } | undefined;
  next?: { title: string; href: string } | undefined;
  rawHref?: string | undefined;
}

const { title, description, date, category, readingTime, prev, next, rawHref } = Astro.props;
const catLabel = categoryLabel(category);
const year = new Date().getFullYear();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} — Preah</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <link rel="alternate" type="application/rss+xml" title="Preah's Blog" href="/rss.xml" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Crimson+Pro:ital,wght@0,300..700;1,300..600&family=Source+Serif+4:opsz,wght@8..60,300..600&family=Spline+Sans+Mono:wght@400;500&family=Newsreader:opsz,wght@6..72,400..600&display=swap"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.16.11/dist/katex.min.css" />
  </head>
  <body>
    <div class="wrap" style="max-width: 720px;">

      <!-- ---------- site header ---------- -->
      <header class="site-head">
        <div class="brand-row">
          <span class="brand-icon" aria-hidden="true">
            <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.0" stroke-linecap="round" stroke-linejoin="round"><path d="M10 2v2"/><path d="M14 2v2"/><path d="M16 8a1 1 0 0 1 1 1v8a4 4 0 0 1-4 4H7a4 4 0 0 1-4-4V9a1 1 0 0 1 1-1h14a4 4 1 1 1 0 8h-1"/><path d="M6 2v2"/></svg>
          </span>
          <a class="brand" href="/">Preah</a>
        </div>
        <nav class="nav">
          <a href="/">home</a>
          <a href="/blog" class="active">blog</a>
          <a href="/portfolio">portfolio</a>
          <a href="/about">about</a>
        </nav>
      </header>

      <!-- ---------- article ---------- -->
      <article>
        <header class="article-head">
          <h1>{title}</h1>
          <div class="meta-box">
            <!-- breadcrumb -->
            <div class="meta-row crumb">
              <span class="mi" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round" stroke-linecap="round"><path d="M5 3l14 9-14 9V3z"/></svg>
              </span>
              <a href="/blog">Blog</a>
              <span class="sep">&#8594;</span>
              <a href={`/blog?folder=${category}`}>{catLabel}</a>
              <span class="sep">&#8594;</span>
              <span class="crumb-here">{title}</span>
            </div>
            <!-- date -->
            <div class="meta-row">
              <span class="mi" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"><rect x="3" y="4" width="18" height="17" rx="2"/><path d="M3 9h18M8 2v4M16 2v4"/></svg>
              </span>
              <span>Posted {date}</span>
            </div>
            <!-- reading time -->
            <div class="meta-row">
              <span class="mi" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2"/></svg>
              </span>
              <span>{readingTime}</span>
            </div>
            {rawHref && (
              <div class="meta-row">
                <span class="mi" aria-hidden="true">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="12" y1="12" x2="12" y2="18"/><line x1="9" y1="15" x2="15" y2="15"/></svg>
                </span>
                <a href={rawHref} download>Download raw .md</a>
              </div>
            )}
          </div>
        </header>

        <!-- rendered Markdown goes here -->
        <div class="prose">
          <slot />
        </div>

        <!-- ---------- prev / next ---------- -->
        <footer class="article-foot">
          <nav class="post-nav" aria-label="Post navigation">
            {prev
              ? <a href={prev.href} class="post-nav-item prev">
                  <div class="dir">&#8592; previous</div>
                  <div class="ttl">{prev.title}</div>
                </a>
              : <span></span>
            }
            {next &&
              <a href={next.href} class="post-nav-item next">
                <div class="dir">next &#8594;</div>
                <div class="ttl">{next.title}</div>
              </a>
            }
          </nav>
        </footer>
      </article>

      <!-- ---------- footer ---------- -->
      <footer class="site-foot">
        <span class="foot-brand">Preah</span>
        <span class="foot-dot">&middot;</span>
        <span>{year}</span>
        <span class="foot-spacer"></span>
        <a href="https://git.preahs.com/preah">Forgejo</a>
        <a href="mailto:contact@preahs.com">Email</a>
        <a href="/rss.xml">RSS</a>
        <a href="https://signal.me/#eu/7FQaEphPdhSrlUCPuqr8awsHVYUSiJ9CGua_YktOEMge3oIT-itMcKuS2r3k6x8Q">Signal</a>
        <a href="https://matrix.to/#/@preshavocado:snowberry.social">Matrix</a>
      </footer>

    </div>
  </body>
</html>

<script>
  // Mermaid — client-side rendering (avoids Playwright dependency in build environments)
  // Only loads mermaid.js when the page actually contains diagrams.
  const mermaidBlocks = document.querySelectorAll('code.language-mermaid');
  if (mermaidBlocks.length > 0) {
    const script = document.createElement('script');
    script.type = 'module';
    script.textContent = `
      import mermaid from 'https://cdn.jsdelivr.net/npm/mermaid@11/dist/mermaid.esm.min.mjs';
      mermaid.initialize({ startOnLoad: false, theme: 'neutral' });
      const blocks = document.querySelectorAll('code.language-mermaid');
      for (const code of blocks) {
        const pre = code.parentElement;
        const source = code.textContent ?? '';
        const id = 'mermaid-' + Math.random().toString(36).slice(2);
        try {
          const { svg } = await mermaid.render(id, source);
          const wrapper = document.createElement('div');
          wrapper.className = 'mermaid-diagram-wrapper';
          wrapper.innerHTML = svg;
          pre.replaceWith(wrapper);
        } catch (e) {
          console.warn('Mermaid render failed:', e);
        }
      }
    `;
    document.head.appendChild(script);
  }
</script>

<script>
  // Copy button for code blocks
  document.querySelectorAll('.prose pre').forEach((pre) => {
    const wrapper = document.createElement('div');
    wrapper.className = 'code-block-wrap';
    pre.parentNode?.insertBefore(wrapper, pre);
    wrapper.appendChild(pre);

    const btn = document.createElement('button');
    btn.className = 'copy-btn';
    btn.setAttribute('aria-label', 'Copy code');
    btn.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect width="14" height="14" x="8" y="8" rx="2" ry="2"/><path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"/></svg>`;
    wrapper.appendChild(btn);

    btn.addEventListener('click', async () => {
      const code = pre.querySelector('code')?.innerText ?? pre.innerText;
      await navigator.clipboard.writeText(code);
      btn.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg>`;
      btn.classList.add('copied');
      setTimeout(() => {
        btn.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect width="14" height="14" x="8" y="8" rx="2" ry="2"/><path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"/></svg>`;
        btn.classList.remove('copied');
      }, 1800);
    });
  });
</script>

<style>
  /* ---------- article header ---------- */
  .article-head h1 {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: clamp(1.9rem, 4.5vw, 2.7rem);
    line-height: 1.05;
    letter-spacing: -0.025em;
    margin-bottom: 1.25rem;
    color: var(--ink);
  }

  .meta-box {
    border: 1.5px dashed var(--rule);
    border-radius: var(--radius);
    padding: 1rem 1.25rem;
    margin-bottom: 1.75rem;
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
  }

  .meta-row {
    display: flex;
    align-items: center;
    gap: 0.55rem;
    font-size: 0.95rem;
    color: var(--ink-soft);
  }

  .meta-row .mi {
    flex: none;
    color: var(--ink-faint);
    display: flex;
    width: 1.15rem;
  }

  .meta-row .mi svg { width: 1.1rem; height: 1.1rem; display: block; }

  .crumb { flex-wrap: wrap; }
  .crumb a { color: var(--accent); text-decoration: none; }
  .crumb a:hover { text-decoration: underline; text-underline-offset: 3px; }
  .crumb .sep { color: var(--ink-faint); font-size: 0.85rem; }
  .crumb-here { color: var(--ink); }

  .meta-row a:not(.crumb a) {
    color: var(--ink-soft);
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 3px;
    text-decoration-color: var(--rule);
    transition: color 0.15s, text-decoration-color 0.15s;
  }
  .meta-row a:not(.crumb a):hover {
    color: var(--accent);
    text-decoration-color: var(--accent-soft);
  }

  /* ---------- prose ---------- */
  .prose { font-size: 1.12rem; line-height: 1.75; color: var(--ink); }
  .prose :global(> * + *) { margin-top: 1.35rem; }

  .prose :global(h2) {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 1.6rem;
    letter-spacing: -0.015em;
    line-height: 1.2;
    margin-top: 2.5rem;
    color: var(--ink);
  }

  .prose :global(h3) {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 1.28rem;
    margin-top: 2rem;
    color: var(--ink);
  }

  .prose :global(p) { margin-top: 1.35rem; }
  .prose :global(p:first-child) { margin-top: 0; }

  .prose :global(strong) { font-weight: 600; }

  .prose :global(em) { font-style: italic; }

  .prose :global(a) {
    color: var(--accent);
    text-decoration: underline;
    text-decoration-thickness: 1.5px;
    text-underline-offset: 3px;
    text-decoration-color: var(--accent-soft);
    transition: text-decoration-color 0.15s;
  }
  .prose :global(a:hover) { text-decoration-color: var(--accent); }

  .prose :global(blockquote) {
    position: relative;
    font-family: var(--font-quote);
    font-style: italic;
    font-size: 1.15rem;
    color: var(--ink-soft);
    line-height: 1.6;
    padding: 1.1rem 1.4rem 1.1rem 3rem;
    border-left: 3px solid var(--accent);
    border-radius: 0 var(--radius) var(--radius) 0;
    background: oklch(96% 0.01 70);
    margin-top: 1.35rem;
  }
  .prose :global(blockquote::before) {
    content: '\201C';
    position: absolute;
    left: 0.6rem;
    top: 0.2rem;
    font-family: var(--font-quote);
    font-size: 2.8rem;
    line-height: 1;
    color: var(--accent);
    opacity: 0.5;
  }
  .prose :global(blockquote p) { margin-top: 0.6rem; }
  .prose :global(blockquote p:first-child) { margin-top: 0; }

  .prose :global(code) {
    font-family: var(--font-mono);
    font-size: 0.83em;
    color: oklch(42% 0.14 25);
    padding: 0.15em 0.45em;
    border-radius: 4px;
    background: oklch(92% 0.025 60);
    border: none;
  }

  .prose :global(pre) {
    border-radius: var(--radius);
    padding: 1.1rem 1.3rem;
    overflow-x: auto;
    margin-top: 1.35rem;
    /* background comes from Shiki's dark theme */
    box-shadow: 0 2px 12px oklch(0% 0 0 / 0.18);
  }

  .prose :global(pre code) {
    border: none;
    padding: 0;
    background: none;
    font-size: 0.88em;
    color: inherit;
  }

  .prose :global(ul),
  .prose :global(ol) {
    padding-left: 1.4rem;
    margin-top: 1.35rem;
  }

  .prose :global(li) { margin-top: 0.4rem; }
  .prose :global(li::marker) { color: var(--accent); }

  .prose :global(hr) {
    border: none;
    border-top: 1.5px dashed var(--rule);
    margin: 1.75rem 0;
  }

  /* ---------- post nav ---------- */
  .article-foot {
    margin-top: 2.75rem;
    padding-top: 1.75rem;
    border-top: 1.5px dashed var(--rule);
  }

  .post-nav {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .post-nav-item {
    flex: 1;
    min-width: 180px;
    text-decoration: none;
    color: inherit;
    padding: 0.9rem 1.1rem;
    border: 1.5px dashed var(--rule);
    border-radius: var(--radius);
    transition: border-color 0.18s;
    display: block;
  }

  .post-nav-item:hover { border-color: var(--accent); }

  .post-nav-item .dir {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--ink-faint);
    margin-bottom: 0.3rem;
  }

  .post-nav-item .ttl {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 1rem;
    color: var(--ink);
  }

  .post-nav-item:hover .ttl { color: var(--accent); }
  .post-nav-item.next { text-align: right; }

  /* ---------- tables ---------- */
  .prose :global(table) {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.95em;
    margin-top: 1.35rem;
  }
  .prose :global(th) {
    font-family: var(--font-mono);
    font-size: 0.82em;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--ink-soft);
    background: var(--paper-card);
    padding: 0.55rem 0.85rem;
    border: 1.5px dashed var(--rule);
    text-align: left;
  }
  .prose :global(td) {
    padding: 0.5rem 0.85rem;
    border: 1.5px dashed var(--rule);
    vertical-align: top;
  }
  .prose :global(tr:nth-child(even) td) {
    background: oklch(97.5% 0.006 85);
  }

  /* ---------- images ---------- */
  .prose :global(img) {
    max-width: 100%;
    border-radius: var(--radius);
    display: block;
    margin: 1.35rem auto;
  }
  .prose :global(figure) { margin: 1.75rem 0; text-align: center; }
  .prose :global(figcaption) {
    font-family: var(--font-mono);
    font-size: 0.8em;
    color: var(--ink-faint);
    margin-top: 0.4rem;
  }

  /* ---------- mark / highlight ==text== ---------- */
  .prose :global(mark) {
    background: oklch(90% 0.12 85);
    color: var(--ink);
    padding: 0.05em 0.25em;
    border-radius: 3px;
  }

  /* ---------- definition lists ---------- */
  .prose :global(dl) { margin-top: 1.35rem; }
  .prose :global(dt) {
    font-weight: 600;
    color: var(--ink);
    margin-top: 0.85rem;
  }
  .prose :global(dd) {
    margin-left: 1.5rem;
    color: var(--ink-soft);
    margin-top: 0.2rem;
  }
  .prose :global(dd + dd) { margin-top: 0.1rem; }

  /* ---------- superscript / subscript ---------- */
  .prose :global(sup),
  .prose :global(sub) {
    font-size: 0.75em;
    line-height: 0;
  }

  /* ---------- external link icon ---------- */
  .prose :global(.ext-link-icon) {
    display: inline-block;
    vertical-align: middle;
    margin-left: 0.2em;
    margin-bottom: 0.1em;
    opacity: 0.6;
    flex-shrink: 0;
  }

  /* ---------- copy button ---------- */
  .prose :global(.code-block-wrap) {
    position: relative;
    margin-top: 1.35rem;
  }
  .prose :global(.code-block-wrap pre) {
    margin-top: 0;
  }
  .prose :global(.copy-btn) {
    position: absolute;
    top: 0.5rem;
    right: 0.55rem;
    background: oklch(30% 0.02 240 / 0.7);
    border: 1px solid oklch(55% 0.04 240 / 0.5);
    border-radius: 5px;
    padding: 0.3rem 0.4rem;
    cursor: pointer;
    color: oklch(75% 0.04 240);
    display: flex;
    align-items: center;
    opacity: 0;
    transition: opacity 0.15s, color 0.15s, background 0.15s;
  }
  .prose :global(.code-block-wrap:hover .copy-btn) { opacity: 1; }
  .prose :global(.copy-btn:hover) { color: oklch(95% 0.02 240); background: oklch(38% 0.03 240 / 0.9); }
  .prose :global(.copy-btn.copied) { color: oklch(75% 0.16 145); opacity: 1; }

  /* ---------- GitHub-style alerts ---------- */
  .prose :global(.markdown-alert) {
    border-left: 4px solid;
    border-radius: 0 var(--radius) var(--radius) 0;
    padding: 0.9rem 1.2rem;
    margin-top: 1.35rem;
  }
  .prose :global(.markdown-alert-title) {
    font-family: var(--font-mono);
    font-size: 0.8em;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    display: flex;
    align-items: center;
    gap: 0.45rem;
    margin-bottom: 0.5rem;
  }
  .prose :global(.markdown-alert p) { margin-top: 0.4rem; }
  .prose :global(.markdown-alert p:first-of-type) { margin-top: 0; }

  .prose :global(.markdown-alert-note) {
    border-color: oklch(58% 0.16 250);
    background: oklch(96% 0.025 250);
  }
  .prose :global(.markdown-alert-note .markdown-alert-title) { color: oklch(48% 0.18 250); }

  .prose :global(.markdown-alert-tip) {
    border-color: oklch(56% 0.18 145);
    background: oklch(96% 0.03 145);
  }
  .prose :global(.markdown-alert-tip .markdown-alert-title) { color: oklch(44% 0.20 145); }

  .prose :global(.markdown-alert-important) {
    border-color: oklch(56% 0.20 295);
    background: oklch(96% 0.025 295);
  }
  .prose :global(.markdown-alert-important .markdown-alert-title) { color: oklch(46% 0.22 295); }

  .prose :global(.markdown-alert-warning) {
    border-color: oklch(68% 0.17 70);
    background: oklch(97% 0.03 80);
  }
  .prose :global(.markdown-alert-warning .markdown-alert-title) { color: oklch(50% 0.18 60); }

  .prose :global(.markdown-alert-caution) {
    border-color: oklch(58% 0.20 25);
    background: oklch(96% 0.03 25);
  }
  .prose :global(.markdown-alert-caution .markdown-alert-title) { color: oklch(48% 0.22 25); }

  /* ---------- mermaid ---------- */
  /* While JS loads, the raw <pre> placeholder gets a subtle unrendered style */
  .prose :global(pre:has(> code.language-mermaid)) {
    background: var(--paper-card);
    border: 1.5px dashed var(--rule);
    box-shadow: none;
    opacity: 0.5;
  }
  .prose :global(.mermaid-diagram-wrapper) {
    text-align: center;
    margin-top: 1.35rem;
  }
  .prose :global(.mermaid-diagram-wrapper svg) {
    max-width: 100%;
    height: auto;
    border: 1.5px dashed var(--rule);
    border-radius: var(--radius);
    padding: 1rem;
    background: var(--paper-card);
  }

  /* ---------- KaTeX ---------- */
  .prose :global(.katex-display) {
    overflow-x: auto;
    padding: 0.5rem 0;
  }
  .prose :global(.katex) { font-size: 1.05em; }

  /* ---------- task list checkboxes ---------- */
  .prose :global(li:has(> input[type="checkbox"])) {
    list-style: none;
    margin-left: -1rem;
  }
  /* Restore normal indent for nested task items — only top-level pulls back */
  .prose :global(li li:has(> input[type="checkbox"])) {
    margin-left: 0;
  }
  .prose :global(li > input[type="checkbox"]) {
    width: 1em;
    height: 1em;
    accent-color: var(--accent);
    cursor: default;
    margin-right: 0.45rem;
    position: relative;
    top: 0.12em;
  }
  .prose :global(li:has(> input[type="checkbox"]:checked) > :not(ul):not(ol)) {
    text-decoration: line-through;
    text-decoration-color: var(--accent);
    color: var(--ink-soft);
  }

  /* ---------- kbd ---------- */
  .prose :global(kbd) {
    font-family: var(--font-mono);
    font-size: 0.8em;
    padding: 0.1em 0.45em;
    border: 1.5px solid var(--rule);
    border-bottom-width: 2.5px;
    border-radius: 4px;
    background: var(--paper-card);
    color: var(--ink-soft);
  }

  /* ---------- footnotes ---------- */
  .prose :global(.footnotes) {
    border-top: 1.5px dashed var(--rule);
    margin-top: 2.5rem;
    padding-top: 1rem;
    font-size: 0.9em;
    color: var(--ink-soft);
  }
  .prose :global(.footnote-ref a),
  .prose :global(.footnotes a) {
    font-family: var(--font-mono);
    font-size: 0.8em;
  }
</style>
