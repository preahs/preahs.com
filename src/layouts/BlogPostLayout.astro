---
import '../styles/global.css';
import { categoryLabel } from '../lib/blog';

interface Props {
  title: string;
  description: string;
  date: string;         // pre-formatted string, e.g. "Sun May. 17, 2026"
  category: string;     // category id, e.g. "codex"
  readingTime: string;  // e.g. "5 min read"
  prev?: { title: string; href: string } | undefined;
  next?: { title: string; href: string } | undefined;
}

const { title, description, date, category, readingTime, prev, next } = Astro.props;
const catLabel = categoryLabel(category);
const year = new Date().getFullYear();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} — Preah</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <link rel="alternate" type="application/rss+xml" title="Preah's Blog" href="/rss.xml" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Crimson+Pro:ital,wght@0,300..700;1,300..600&family=Source+Serif+4:opsz,wght@8..60,300..600&family=Spline+Sans+Mono:wght@400;500&family=Newsreader:opsz,wght@6..72,400..600&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <div class="wrap" style="max-width: 720px;">

      <!-- ---------- site header ---------- -->
      <header class="site-head">
        <span class="brand-icon" aria-hidden="true">
          <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.0" stroke-linecap="round" stroke-linejoin="round"><path d="M10 2v2"/><path d="M14 2v2"/><path d="M16 8a1 1 0 0 1 1 1v8a4 4 0 0 1-4 4H7a4 4 0 0 1-4-4V9a1 1 0 0 1 1-1h14a4 4 1 1 1 0 8h-1"/><path d="M6 2v2"/></svg>
        </span>
        <a class="brand" href="/">Preah</a>
        <nav class="nav">
          <a href="/">home</a>
          <a href="/blog" class="active">blog</a>
          <a href="/portfolio">portfolio</a>
          <a href="/about">about</a>
        </nav>
      </header>

      <!-- ---------- article ---------- -->
      <article>
        <header class="article-head">
          <h1>{title}</h1>
          <div class="meta-box">
            <!-- breadcrumb -->
            <div class="meta-row crumb">
              <span class="mi" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round" stroke-linecap="round"><path d="M5 3l14 9-14 9V3z"/></svg>
              </span>
              <a href="/blog">Blog</a>
              <span class="sep">&#8594;</span>
              <a href={`/blog?folder=${category}`}>{catLabel}</a>
              <span class="sep">&#8594;</span>
              <span class="crumb-here">{title}</span>
            </div>
            <!-- date -->
            <div class="meta-row">
              <span class="mi" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"><rect x="3" y="4" width="18" height="17" rx="2"/><path d="M3 9h18M8 2v4M16 2v4"/></svg>
              </span>
              <span>Posted {date}</span>
            </div>
            <!-- reading time -->
            <div class="meta-row">
              <span class="mi" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2"/></svg>
              </span>
              <span>{readingTime}</span>
            </div>
          </div>
        </header>

        <!-- rendered Markdown goes here -->
        <div class="prose">
          <slot />
        </div>

        <!-- ---------- prev / next ---------- -->
        <footer class="article-foot">
          <nav class="post-nav" aria-label="Post navigation">
            {prev
              ? <a href={prev.href} class="post-nav-item prev">
                  <div class="dir">&#8592; previous</div>
                  <div class="ttl">{prev.title}</div>
                </a>
              : <span></span>
            }
            {next &&
              <a href={next.href} class="post-nav-item next">
                <div class="dir">next &#8594;</div>
                <div class="ttl">{next.title}</div>
              </a>
            }
          </nav>
        </footer>
      </article>

      <!-- ---------- footer ---------- -->
      <footer class="site-foot">
        <span class="foot-brand">Preah</span>
        <span class="foot-dot">&middot;</span>
        <span>{year}</span>
        <span class="foot-spacer"></span>
        <a href="https://git.preahs.com/preah">Forgejo</a>
        <a href="mailto:contact@preahs.com">Email</a>
        <a href="/rss.xml">RSS</a>
        <a href="https://signal.me/#eu/7FQaEphPdhSrlUCPuqr8awsHVYUSiJ9CGua_YktOEMge3oIT-itMcKuS2r3k6x8Q">Signal</a>
        <a href="https://matrix.to/#/@preshavocado:snowberry.social">Matrix</a>
      </footer>

    </div>
  </body>
</html>

<style>
  /* ---------- article header ---------- */
  .article-head h1 {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: clamp(1.9rem, 4.5vw, 2.7rem);
    line-height: 1.05;
    letter-spacing: -0.025em;
    margin-bottom: 1.25rem;
    color: var(--ink);
  }

  .meta-box {
    border: 1.5px dashed var(--rule);
    border-radius: var(--radius);
    padding: 1rem 1.25rem;
    margin-bottom: 1.75rem;
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
  }

  .meta-row {
    display: flex;
    align-items: center;
    gap: 0.55rem;
    font-size: 0.95rem;
    color: var(--ink-soft);
  }

  .meta-row .mi {
    flex: none;
    color: var(--ink-faint);
    display: flex;
    width: 1.15rem;
  }

  .meta-row .mi svg { width: 1.1rem; height: 1.1rem; display: block; }

  .crumb { flex-wrap: wrap; }
  .crumb a { color: var(--accent); text-decoration: none; }
  .crumb a:hover { text-decoration: underline; text-underline-offset: 3px; }
  .crumb .sep { color: var(--ink-faint); font-size: 0.85rem; }
  .crumb-here { color: var(--ink); }

  /* ---------- prose ---------- */
  .prose { font-size: 1.12rem; line-height: 1.75; color: var(--ink); }
  .prose :global(> * + *) { margin-top: 1.35rem; }

  .prose :global(h2) {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 1.6rem;
    letter-spacing: -0.015em;
    line-height: 1.2;
    margin-top: 2.5rem;
    color: var(--ink);
  }

  .prose :global(h3) {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 1.28rem;
    margin-top: 2rem;
    color: var(--ink);
  }

  .prose :global(p) { margin-top: 1.35rem; }
  .prose :global(p:first-child) { margin-top: 0; }

  .prose :global(strong) { font-weight: 600; }

  .prose :global(em) { font-style: italic; }

  .prose :global(a) {
    color: var(--accent);
    text-decoration: underline;
    text-decoration-thickness: 1.5px;
    text-underline-offset: 3px;
    text-decoration-color: var(--accent-soft);
    transition: text-decoration-color 0.15s;
  }
  .prose :global(a:hover) { text-decoration-color: var(--accent); }

  .prose :global(blockquote) {
    font-family: var(--font-quote);
    font-style: italic;
    font-size: 1.18rem;
    color: var(--ink-soft);
    line-height: 1.5;
    padding: 1rem 1.3rem;
    border: 1.5px dashed var(--rule);
    border-radius: var(--radius);
    margin-top: 1.35rem;
  }

  .prose :global(code) {
    font-family: var(--font-mono);
    font-size: 0.86em;
    color: oklch(48% 0.10 40);
    padding: 0.08em 0.4em;
    border-radius: 4px;
    border: 1.5px dashed var(--rule);
    background: oklch(96% 0.012 85);
  }

  .prose :global(pre) {
    border: 1.5px dashed var(--rule);
    border-radius: var(--radius);
    padding: 1rem 1.2rem;
    overflow-x: auto;
    background: var(--paper-card);
    margin-top: 1.35rem;
  }

  .prose :global(pre code) {
    border: none;
    padding: 0;
    background: none;
    font-size: 0.9em;
    color: var(--ink);
  }

  .prose :global(ul),
  .prose :global(ol) {
    padding-left: 1.4rem;
    margin-top: 1.35rem;
  }

  .prose :global(li) { margin-top: 0.4rem; }
  .prose :global(li::marker) { color: var(--accent); }

  .prose :global(hr) {
    border: none;
    border-top: 1.5px dashed var(--rule);
    margin: 1.75rem 0;
  }

  /* ---------- post nav ---------- */
  .article-foot {
    margin-top: 2.75rem;
    padding-top: 1.75rem;
    border-top: 1.5px dashed var(--rule);
  }

  .post-nav {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .post-nav-item {
    flex: 1;
    min-width: 180px;
    text-decoration: none;
    color: inherit;
    padding: 0.9rem 1.1rem;
    border: 1.5px dashed var(--rule);
    border-radius: var(--radius);
    transition: border-color 0.18s;
    display: block;
  }

  .post-nav-item:hover { border-color: var(--accent); }

  .post-nav-item .dir {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--ink-faint);
    margin-bottom: 0.3rem;
  }

  .post-nav-item .ttl {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 1rem;
    color: var(--ink);
  }

  .post-nav-item:hover .ttl { color: var(--accent); }
  .post-nav-item.next { text-align: right; }
</style>
